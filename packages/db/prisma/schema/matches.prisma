// Matches schema

enum ConfidenceBand {
    auto
    suggest
    review
    none

    @@map("confidence_band")
}

enum MatchStatus {
    pending
    confirmed
    rejected
    auto_confirmed

    @@map("match_status")
}

model Match {
    id              String         @id @default(uuid()) @db.Uuid
    offerId         String         @map("offer_id") @db.Uuid
    requestId       String         @map("request_id") @db.Uuid
    score           Decimal        @db.Decimal(5, 4)
    confidenceBand  ConfidenceBand @map("confidence_band")
    status          MatchStatus    @default(pending)
    operatorNote    String?        @map("operator_note")
    medicationName  String         @map("medication_name")
    offerQuantity   Int            @map("offer_quantity")
    requestQuantity Int            @map("request_quantity")
    offerPrice      Decimal?       @map("offer_price") @db.Decimal(10, 2)
    maxPrice        Decimal?       @map("max_price") @db.Decimal(10, 2)
    createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
    updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

    // Relations
    offer   Offer   @relation(fields: [offerId], references: [id])
    request Request @relation(fields: [requestId], references: [id])

    @@map("matches")
}

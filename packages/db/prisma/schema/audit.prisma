// Audit log schema
//
// AUDIT TRAIL INTEGRITY:
// The operatorId is nullable to preserve audit history when users are deleted.
// When a user is deleted, their audit logs remain with operatorId set to NULL,
// maintaining a complete audit trail for compliance and forensic purposes.

model AuditLog {
    id         String   @id @default(uuid()) @db.Uuid
    action     String
    entityType String   @map("entity_type")
    entityId   String   @map("entity_id")
    operatorId String?  @map("operator_id") @db.Uuid
    operator   User?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)
    details    Json?
    createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

    @@index([operatorId])
    @@map("audit_log")
}

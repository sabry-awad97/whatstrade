# Docker Compose Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# PostgreSQL Configuration
POSTGRES_DB=whatstrade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5433

# Database Connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/whatstrade

# WhatsApp Service Configuration
WHATSAPP_SERVICE_PORT=8080
WHATSAPP_SERVICE_URL=http://whatsapp-service:8080
LOG_LEVEL=info
WHATSAPP_LOG_LEVEL=INFO

# Server Configuration
SERVER_PORT=3000
NODE_ENV=production

# AI Configuration (for Tauri app)
# For local development with Ollama/LM Studio, use a dummy API key
# For production with OpenAI/Anthropic, use a real API key
# Note: Empty API keys are not allowed - use a placeholder for local models
AI_API_KEY=sk-local-model-dummy-key-12345
AI_MODEL=gemma4:latest
AI_BASE_URL=http://localhost:12434/engines/v1

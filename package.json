{
  "name": "workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.9",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "start": "bun run index.ts",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @workspace/db db:push",
    "db:studio": "turbo -F @workspace/db db:studio",
    "db:generate": "turbo -F @workspace/db db:generate",
    "db:migrate": "turbo -F @workspace/db db:migrate",
    "db:start": "turbo -F @workspace/db db:start",
    "db:watch": "turbo -F @workspace/db db:watch",
    "db:stop": "turbo -F @workspace/db db:stop",
    "db:down": "turbo -F @workspace/db db:down"
  },
  "dependencies": {
    "@workspace/env": "workspace:*",
    "dotenv": "catalog:",
    "recharts": "^3.8.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@workspace/config": "workspace:*",
    "concurrently": "^9.2.1",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "vitest": "^4.1.6"
  },
  "packageManager": "bun@1.3.5"
}

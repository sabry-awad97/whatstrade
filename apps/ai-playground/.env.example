# AI Model Configuration
# Base URL for OpenAI-compatible API endpoint
AI_BASE_URL=http://localhost:12434/engines/v1

# Model name/identifier
AI_MODEL=gemma4

# API Key (optional, use "not-needed" for local models)
AI_API_KEY=not-needed

# Concurrency limit for parallel requests (default: 5)
# Lower values = less server load, higher values = faster throughput
CONCURRENCY_LIMIT=5

# Tauri Application Environment Variables
# Copy this file to .env and fill in your actual values

# Server URL for the web application
VITE_SERVER_URL=http://localhost:3000

# Database Configuration
# For local development with Docker Compose PostgreSQL
# Note: Use localhost:5433 (mapped port) when connecting from host machine
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5433/whatstrade

# JWT Secret for authentication tokens
# IMPORTANT: Change this to a secure random string in production
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-secret-in-production

# Migration Performance Optimization
# Set SKIP_MIGRATIONS=true to skip schema sync entirely (faster startup ~19s -> <1s)
# Useful when database schema is already up-to-date
# Uncomment to enable:
# SKIP_MIGRATIONS=true
